@page "/housing-units"
@rendermode InteractiveServer
@using AzilEdu.Shared.Models
@using System.Net.Http.Json

@inject HttpClient Http

<MudText Typo="Typo.h4" GutterBottom="true">
    Smještajne jedinice
</MudText>

<MudText Typo="Typo.body1" Class="mb-4">
    Prikazujemo probne podatke o smještajnim jedinicama u azilu. Podaci se trenutno ne čitaju iz baze, nego iz lokalne liste u ovoj Razor komponenti.
</MudText>

<MudGrid Class="mb-4">

    <MudItem xs="12" sm="3">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.subtitle2">Ukupno jedinica</MudText>
            <MudText Typo="Typo.h5">@TotalHousingUnits</MudText>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" sm="3">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.subtitle2">Aktivne</MudText>
            <MudText Typo="Typo.h5">@ActiveHousingUnits</MudText>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" sm="3">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.subtitle2">Pune</MudText>
            <MudText Typo="Typo.h5">@FullHousingUnits</MudText>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" sm="3">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.subtitle2">Slobodni kapacitet</MudText>
            <MudText Typo="Typo.h5">@FreeCapacity</MudText>
        </MudPaper>
    </MudItem>

</MudGrid>

<MudButtonGroup Color="Color.Primary"
                Variant="Variant.Outlined"
                Class="mb-4">

    <MudButton OnClick="@ShowAllHousingUnits">
        Sve
    </MudButton>

    <MudButton OnClick="@ShowActiveHousingUnits">
        Aktivne
    </MudButton>

    <MudButton OnClick="@ShowFullHousingUnits">
        Pune
    </MudButton>

    <MudButton OnClick="@ShowAvailableHousingUnits">
        Slobodno
    </MudButton>

</MudButtonGroup>

<MudTable Items="@FilteredHousingUnits"
          Hover="true"
          Striped="true"
          Bordered="true"
          Dense="true">

    <HeaderContent>

        <MudTh>Slika</MudTh>
        <MudTh>Naziv</MudTh>
        <MudTh>Tip</MudTh>
        <MudTh>Kapacitet</MudTh>
        <MudTh>Zauzeto</MudTh>
        <MudTh>Slobodno</MudTh>
        <MudTh>Zadnje čišćenje</MudTh>
        <MudTh>Status</MudTh>

    </HeaderContent>

    <RowTemplate>

        <MudTd DataLabel="Slika">
            <MudAvatar Size="Size.Large">
                <MudImage Src="@context.ImageUrl"
                          Alt="@context.Name" />
            </MudAvatar>
        </MudTd>

        <MudTd DataLabel="Naziv">
            @context.Name
        </MudTd>

        <MudTd DataLabel="Tip">
            @context.UnitType
        </MudTd>

        <MudTd DataLabel="Kapacitet">
            @context.Capacity
        </MudTd>

        <MudTd DataLabel="Zauzeto">
            @context.Occupied
        </MudTd>

        <MudTd DataLabel="Slobodno">
            @GetFreeCapacity(context)
        </MudTd>

        <MudTd DataLabel="Zadnje čišćenje">
            @GetCleaningDateText(context)
        </MudTd>

        <MudTd DataLabel="Status">
            <MudChip T="string"
                     Color="@GetUnitStatusColor(context)"
                     Variant="Variant.Filled">
                @GetUnitStatusText(context)
            </MudChip>
        </MudTd>

    </RowTemplate>

</MudTable>
@code {
