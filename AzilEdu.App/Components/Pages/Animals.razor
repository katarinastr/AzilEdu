
@page "/animals"
@rendermode InteractiveServer
@using AzilEdu.Shared.Models
@using System.Net.Http.Json
@inject HttpClient Http

<MudText Typo="Typo.h3" GutterBottom="true">
    Animals
</MudText>

<MudText Typo="Typo.body1" Class="mb-4">
    Pregled životinja koje se nalaze u sustavu azila.
</MudText>

<MudGrid>

    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">

            <MudImage Src="images/pas.jfif"
                      Alt="Životinje u azilu"
                      Fluid="true"
                      Class="mb-3" />

            <MudText Typo="Typo.h6">
                Sve životinje
            </MudText>

            <MudText Typo="Typo.body2">
                Pregled svih životinja evidentiranih u azilu.
            </MudText>

            <MudStack Row="true" Spacing="2" Class="mt-3">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary">
                    Otvori pregled
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Secondary">
                    Detalji
                </MudButton>
            </MudStack>

        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">

            <MudImage Src="images/pas.jfif"
                      Alt="Vrste i pasmine"
                      Fluid="true"
                      Class="mb-3" />

            <MudText Typo="Typo.h6">
                Vrste i pasmine
            </MudText>

            <MudText Typo="Typo.body2">
                Organizacija životinja prema vrstama i pasminama.
            </MudText>

            <MudStack Row="true" Spacing="2" Class="mt-3">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary">
                    Pogledaj vrste
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Secondary">
                    Detalji
                </MudButton>
            </MudStack>

        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">

            <MudImage Src="images/smjestaj.jfif"
                      Alt="Smještaj životinja"
                      Fluid="true"
                      Class="mb-3" />

            <MudText Typo="Typo.h6">
                Smještaj
            </MudText>

            <MudText Typo="Typo.body2">
                Pregled bokseva, kaveza i drugih smještajnih jedinica.
            </MudText>

            <MudStack Row="true" Spacing="2" Class="mt-3">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary">
                    Pogledaj smještaj
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Secondary">
                    Detalji
                </MudButton>
            </MudStack>

        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">

            <MudImage Src="images/smjestaj.jfif"
                      Alt="Housing Units"
                      Fluid="true"
                      Class="mb-3" />

            <MudText Typo="Typo.h6">
                Housing Units
            </MudText>

            <MudText Typo="Typo.body2">
                Pregled bokseva, kaveza i drugih smještajnih jedinica.
            </MudText>

            <MudStack Row="true" Spacing="2" Class="mt-3">

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary">
                    Pogledaj smještaj
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Secondary">
                    Detalji
                </MudButton>

            </MudStack>

        </MudPaper>
    </MudItem>

</MudGrid>

@code{
    private List<Animal> animals = new();
    protected override async Task OnInitializedAsync()
    {
        List<Animal>? result = await Http.GetFromJsonAsync<List<Animal>>("api/animals");
        animals = result ?? new List<Animal>();
    }
}